# Hive — Environment Variables
# Fully decentralized P2P app — no server keys required.
# All relay discovery uses public GunDB community peers.
#
# Copy this file to .env and fill in if you add private relays in the future.
#
# Example (custom private relay — optional):
# GUN_RELAY_1=https://your-relay.example.com/gun
# GUN_RELAY_2=https://your-backup-relay.example.com/gun
#
# App metadata (optional overrides):
# APP_VERSION=2.1.0
# APP_ENV=production
