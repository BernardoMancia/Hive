{
  "name": "hive-relay",
  "version": "1.0.0",
  "description": "GunDB relay — RAM only, zero persistence",
  "main": "relay.js",
  "scripts": {
    "start": "node --max-old-space-size=128 relay.js",
    "pm2": "pm2 start relay.js --name hive-relay --max-memory-restart 150M --restart-delay 3000"
  },
  "dependencies": {
    "gun": "^0.2020.1240"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
