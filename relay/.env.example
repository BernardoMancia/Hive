# Hive Relay — Variáveis de Ambiente
# Copie para .env e preencha os valores reais

# ── Porta do relay GunDB ──────────────────────────────────────────
PORT=8765

# ── Telegram Bot ──────────────────────────────────────────────────
# Token do bot (gerado via @BotFather no Telegram)
TG_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do grupo/canal destino (ex: -1001234567890 para grupos)
# Para descobrir: adicione o bot ao grupo e acesse:
# https://api.telegram.org/bot{TOKEN}/getUpdates
TG_GROUP_ID=-1001234567890
